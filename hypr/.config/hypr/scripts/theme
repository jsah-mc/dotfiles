hex_to_rgb() {
    local hex=${1#\#}
    printf "%d,%d,%d" 0x${hex:0:2} 0x${hex:2:2} 0x${hex:4:2}
}

hex_to_rgb_list() {
    local hex=${1#\#}
    printf "%d, %d, %d" 0x${hex:0:2} 0x${hex:2:2} 0x${hex:4:2}
}

write_qtct_config() {
    local path=$1

    mkdir -p "$(dirname "$path")"
    cat > "$path" <<EOF
[Appearance]
custom_palette=false
icon_theme=Papirus-Dark
standard_dialogs=xdgdesktopportal
style=kvantum
EOF
}

update_qtct() {
    write_qtct_config "$QT5CT_CONF"
    write_qtct_config "$QT6CT_CONF"
}

update_kvantum() {
    local bg=$1
    local bg_alt=$2
    local fg=$3
    local accent=$4
    local disabled=$5
    local link=$6
    local theme_name=Dotfiles
    local base_config="$KVANTUM_BASE_THEME_DIR/$KVANTUM_BASE_THEME_NAME.kvconfig"
    local base_svg="$KVANTUM_BASE_THEME_DIR/$KVANTUM_BASE_THEME_NAME.svg"
    local theme_config="$KVANTUM_THEME_DIR/$theme_name.kvconfig"
    local theme_svg="$KVANTUM_THEME_DIR/$theme_name.svg"
    local tmp_config

    mkdir -p "$KVANTUM_THEME_DIR"

    cp "$base_config" "$theme_config"
    cp "$base_svg" "$theme_svg"

    tmp_config=$(mktemp)
    awk -v window="$bg" \
        -v base="$bg" \
        -v alt_base="$bg_alt" \
        -v button="$bg_alt" \
        -v light="$fg" \
        -v mid_light="$disabled" \
        -v dark="$bg" \
        -v mid="$bg_alt" \
        -v highlight="$accent" \
        -v inactive_highlight="$accent" \
        -v text="$fg" \
        -v window_text="$fg" \
        -v button_text="$fg" \
        -v disabled_text="$disabled" \
        -v tooltip_text="$fg" \
        -v highlight_text="$bg" \
        -v link="$link" \
        -v link_visited="$accent" '
        BEGIN {
            in_colors = 0
        }
        /^\[GeneralColors\]$/ {
            print
            print "window.color=" window
            print "base.color=" base
            print "alt.base.color=" alt_base
            print "button.color=" button
            print "light.color=" light
            print "mid.light.color=" mid_light
            print "dark.color=" dark
            print "mid.color=" mid
            print "highlight.color=" highlight
            print "inactive.highlight.color=" inactive_highlight
            print "text.color=" text
            print "window.text.color=" window_text
            print "button.text.color=" button_text
            print "disabled.text.color=" disabled_text
            print "tooltip.text.color=" tooltip_text
            print "highlight.text.color=" highlight_text
            print "link.color=" link
            print "link.visited.color=" link_visited
            print "progress.indicator.text.color=" text
            in_colors = 1
            next
        }
        in_colors && /^\[/ { in_colors = 0 }
        in_colors { next }
        { print }
    ' "$theme_config" > "$tmp_config"
    mv "$tmp_config" "$theme_config"

    cat > "$KVANTUM_CONFIG" <<EOF
[General]
theme=$theme_name
EOF
}

update_helium() {
    local frame=$1
    local toolbar=$2
    local ntp_background=$3
    local text=$4
    local accent=$5
    local tmp_flags

    mkdir -p "$HELIUM_THEME_DIR"

    cat > "$HELIUM_THEME_DIR/manifest.json" <<EOF
{
    "manifest_version": 2,
    "version": "1.0",
    "name": "Dotfiles Helium Theme",
    "theme": {
        "colors": {
            "frame": [$(hex_to_rgb_list "$frame")],
            "toolbar": [$(hex_to_rgb_list "$toolbar")],
            "ntp_background": [$(hex_to_rgb_list "$ntp_background")],
            "ntp_text": [$(hex_to_rgb_list "$text")],
            "ntp_link": [$(hex_to_rgb_list "$accent")],
            "ntp_section": [$(hex_to_rgb_list "$toolbar")],
            "button_background": [$(hex_to_rgb_list "$accent")]
        }
    }
}
EOF

    tmp_flags=$(mktemp)
    if [ -f "$HELIUM_FLAGS_CONF" ]; then
        awk '
            /^# BEGIN dotfiles helium theme$/ { skip = 1; next }
            /^# END dotfiles helium theme$/ { skip = 0; next }
            !skip { print }
        ' "$HELIUM_FLAGS_CONF" > "$tmp_flags"
    fi

    {
        [ -s "$tmp_flags" ] && cat "$tmp_flags"
        [ -s "$tmp_flags" ] && printf '\n'
        echo "# BEGIN dotfiles helium theme"
        echo "--load-extension=$HELIUM_THEME_DIR"
        echo "# END dotfiles helium theme"
    } > "$HELIUM_FLAGS_CONF"

    rm -f "$tmp_flags"
}

update_helium_from_image() {
    local image=$1
    local json surface on_surface primary on_primary secondary tertiary error outline

    if ! command -v matugen >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
        echo "matugen and jq are required to build the Helium theme from wallpaper" >&2
        return 1
    fi

    if [ -z "$image" ] || [ ! -f "$image" ]; then
        echo "Helium wallpaper theme source not found: $image" >&2
        return 1
    fi

    json=$(matugen image "$image" -j hex --dry-run --source-color-index 0 2>/dev/null || true)
    if [ -z "${json:-}" ]; then
        echo "matugen failed to produce json for Helium wallpaper theme" >&2
        return 1
    fi

    get() { printf "%s" "$json" | jq -r "${1} // empty" 2>/dev/null || true; }
    surface=$(get '.colors.surface.default.color')
    on_surface=$(get '.colors.on_surface.default.color')
    primary=$(get '.colors.primary.default.color')
    on_primary=$(get '.colors.on_primary.default.color')
    secondary=$(get '.colors.secondary.default.color')
    tertiary=$(get '.colors.tertiary.default.color')
    error=$(get '.colors.error.default.color')
    outline=$(get '.colors.outline.default.color')

    surface=${surface:-"#000000"}
    on_surface=${on_surface:-"#ffffff"}
    primary=${primary:-"${error:-$surface}"}
    on_primary=${on_primary:-$on_surface}
    secondary=${secondary:-$primary}
    tertiary=${tertiary:-$primary}
    error=${error:-"#ff0000"}
    outline=${outline:-$on_surface}

    update_helium "$surface" "$surface" "$surface" "$on_surface" "$primary"
}

update_quickshell() {
    local bg=$1
    local surface=$2
    local fg=$3
    local muted=$4
    local accent=$5
    local accent_fg=$6
    local border=$7

    mkdir -p "$(dirname "$QUICKSHELL_BAR_PALETTE")" "$(dirname "$QUICKSHELL_LAUNCHER_PALETTE")" "$(dirname "$QUICKSHELL_JSAH_PALETTE")"

    cat > "$QUICKSHELL_BAR_PALETTE" <<EOF
{
  "bg": "$bg",
  "surface": "$surface",
  "text": "$fg",
  "muted": "$muted",
  "accent": "$accent",
  "accentText": "$accent_fg",
  "border": "$border"
    }
EOF

    cp "$QUICKSHELL_BAR_PALETTE" "$QUICKSHELL_LAUNCHER_PALETTE"
    cp "$QUICKSHELL_BAR_PALETTE" "$QUICKSHELL_JSAH_PALETTE"
}

update_gtk() {
    local bg=$1
    local bg_alt=$2
    local fg=$3
    local accent=$4

    # GTK CSS overrides
    local css_content="@define-color window_bg_color $bg;
@define-color window_fg_color $fg;
@define-color view_bg_color $bg_alt;
@define-color view_fg_color $fg;
@define-color headerbar_bg_color $bg;
@define-color headerbar_fg_color $fg;
@define-color headerbar_border_color $bg;
@define-color headerbar_backdrop_color @window_bg_color;
@define-color card_bg_color $bg_alt;
@define-color card_fg_color $fg;
@define-color card_border_color $bg;
@define-color popover_bg_color $bg_alt;
@define-color popover_fg_color $fg;
@define-color accent_color $accent;
@define-color accent_bg_color $accent;
@define-color accent_fg_color $bg;
@define-color destructive_color #ff7b63;
@define-color destructive_bg_color #ff7b63;
@define-color destructive_fg_color $bg;
@define-color success_color #8ff0a4;
@define-color success_bg_color #8ff0a4;
@define-color success_fg_color $bg;
@define-color warning_color #f8e45c;
@define-color warning_bg_color #f8e45c;
@define-color warning_fg_color $bg;
@define-color error_color #ff7b63;
@define-color error_bg_color #ff7b63;
@define-color error_fg_color $bg;
@define-color window_border_color $bg;"

    echo "$css_content" > "$GTK3_CSS"
    echo "$css_content" > "$GTK4_CSS"
    echo "$css_content" > "$GTK4_DARK_CSS"

    # Update settings.ini to use adw-gtk3
    sed -i "s/gtk-theme-name=.*/gtk-theme-name=adw-gtk3-dark/" "$GTK3_SETTINGS"
    sed -i "s/gtk-theme-name=.*/gtk-theme-name=adw-gtk3-dark/" "$GTK4_SETTINGS"

    # Update xsettingsd
    if [ -f "$XSETTINGS_CONF" ]; then
        sed -i 's/Net\/ThemeName .*/Net\/ThemeName "adw-gtk3-dark"/' "$XSETTINGS_CONF"
    fi
}

