#!/usr/bin/env bash

# Themes
THEMES=("catppuccin" "rose-pine" "gruvbox" "tokyonight" "matugen")

# Paths (use XDG_CONFIG_HOME when available)
XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
HYPR_COLORS="$XDG_CONFIG_HOME/hypr/modules/colors.lua"
HYPRLOCK_CONF="$XDG_CONFIG_HOME/hypr/hyprlock.conf"
WAYBAR_COLORS="$XDG_CONFIG_HOME/waybar/colors/colors.css"
ROFI_COLORS="$XDG_CONFIG_HOME/rofi/colors/matugen.rasi"
QUICKSHELL_BAR_PALETTE="$XDG_CONFIG_HOME/quickshell/bar/palette.json"
QUICKSHELL_LAUNCHER_PALETTE="$XDG_CONFIG_HOME/quickshell/launcher/palette.json"
QUICKSHELL_JSAH_PALETTE="$XDG_CONFIG_HOME/quickshell/jsah/palette.json"
ZED_SETTINGS="$XDG_CONFIG_HOME/zed/settings.json"
HELIUM_THEME_DIR="$XDG_CONFIG_HOME/helium-theme"
HELIUM_FLAGS_CONF="$XDG_CONFIG_HOME/helium-browser-flags.conf"
QT5CT_CONF="$XDG_CONFIG_HOME/qt5ct/qt5ct.conf"
QT6CT_CONF="$XDG_CONFIG_HOME/qt6ct/qt6ct.conf"
KVANTUM_CONFIG="$XDG_CONFIG_HOME/Kvantum/kvantum.kvconfig"
KVANTUM_THEME_DIR="$XDG_CONFIG_HOME/Kvantum/Dotfiles"
KVANTUM_BASE_THEME_DIR="/usr/share/Kvantum/KvAdaptaDark"
KVANTUM_BASE_THEME_NAME="KvAdaptaDark"
GTK3_CSS="$XDG_CONFIG_HOME/gtk-3.0/gtk.css"
GTK4_CSS="$XDG_CONFIG_HOME/gtk-4.0/gtk.css"
GTK4_DARK_CSS="$XDG_CONFIG_HOME/gtk-4.0/gtk-dark.css"
GTK3_SETTINGS="$XDG_CONFIG_HOME/gtk-3.0/settings.ini"
GTK4_SETTINGS="$XDG_CONFIG_HOME/gtk-4.0/settings.ini"
XSETTINGS_CONF="$XDG_CONFIG_HOME/xsettingsd/xsettingsd.conf"
SWAYNC_STYLE="$XDG_CONFIG_HOME/swaync/style.css"
NVIM_THEME="$XDG_CONFIG_HOME/nvim/lua/current-theme.lua"
XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
CURRENT_THEME="$XDG_CACHE_HOME/current_theme"
CURRENT_WALLPAPER="$XDG_CACHE_HOME/current_wallpaper"

find_wallpaper_dir() {
    local candidate

    for candidate in \
        "$HOME/Pictures/wallpaper" \
        "$HOME/Pictures/wallpapers"
    do
        if [ -d "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

list_themes() {
    for theme in "${THEMES[@]}"; do
        echo "$theme"
    done
}

update_hyprlock() {
    local bg=${1#\#}
    local fg=${2#\#}
    local accent=${3#\#}
    local red=${4#\#}

    cat > "$HYPRLOCK_CONF" <<EOF
general {
    no_fade_in = false
    grace = 0
    disable_loading_bar = true
}

background {
    monitor =
    path = screenshot
    blur_passes = 3
    blur_size = 7
    noise = 0.0117
    contrast = 0.8916
    brightness = 0.8172
    vibrancy = 0.1696
    vibrancy_darkness = 0.0
}

input-field {
    monitor =
    size = 300, 60
    outline_thickness = 0
    dots_size = 0.33
    dots_spacing = 0.15
    dots_center = true
    dots_rounding = -1
    outer_color = rgb($accent)
    inner_color = rgb($bg)
    font_color = rgb($fg)
    fade_on_empty = true
    fade_timeout = 1000
    placeholder_text = <i>Input Password...</i>
    hide_input = false
    rounding = 20
    check_color = rgb($accent)
    fail_color = rgb($red)
    fail_text = <i>\$FAIL <b>(\$ATTEMPTS)</b></i>
    capslock_color = -1
    numlock_color = -1
    bothlock_color = -1
    invert_numlock = false
    swap_font_color = false
    position = 0, -50
    halign = center
    valign = center
}

label {
    monitor =
    text = \$TIME
    color = rgba($fg, 1.0)
    font_size = 64
    font_family = Noto Sans
    position = 0, 100
    halign = center
    valign = center
}

label {
    monitor =
    text = cmd[update:1000] echo "\$(date +'%A, %B %d')"
    color = rgba($fg, 0.8)
    font_size = 20
    font_family = Noto Sans
    position = 0, 40
    halign = center
    valign = center
}
EOF
}

update_zed() {
    local theme_name="$1"
    sed -i "s/"dark": ".*"/"dark": "$theme_name"/" "$ZED_SETTINGS"
}

update_nvim() {
    local name=$1
    local colorscheme=$2
    local bg=$3
    local bg_alt=$4
    local fg=$5
    local muted=$6
    local accent=$7
    local red=$8
    local green=$9
    local yellow=${10}
    local blue=${11}
    local magenta=${12}
    local cyan=${13}

    mkdir -p "$(dirname "$NVIM_THEME")"
    cat > "$NVIM_THEME" <<EOF
local name = "$name"
local colorscheme = "$colorscheme"
local palette = {
    bg = "$bg",
    bg_alt = "$bg_alt",
    fg = "$fg",
    muted = "$muted",
    accent = "$accent",
    red = "$red",
    green = "$green",
    yellow = "$yellow",
    blue = "$blue",
    magenta = "$magenta",
    cyan = "$cyan",
}

vim.opt.termguicolors = true

if colorscheme ~= "" then
    pcall(vim.cmd.colorscheme, colorscheme)
end

vim.g.colors_name = name

local set = vim.api.nvim_set_hl
local p = palette

set(0, "Normal", { fg = p.fg, bg = "NONE" })
set(0, "NormalNC", { fg = p.fg, bg = "NONE" })
set(0, "NormalFloat", { fg = p.fg, bg = "NONE" })
set(0, "FloatBorder", { fg = p.accent, bg = "NONE" })
set(0, "Pmenu", { fg = p.fg, bg = "NONE" })
set(0, "PmenuSel", { fg = p.bg, bg = p.accent, bold = true })
set(0, "LineNr", { fg = p.muted, bg = "NONE" })
set(0, "CursorLine", { bg = "NONE" })
set(0, "CursorLineNr", { fg = p.accent, bg = "NONE", bold = true })
set(0, "SignColumn", { bg = "NONE" })
set(0, "EndOfBuffer", { fg = p.bg_alt, bg = "NONE" })
set(0, "StatusLine", { fg = p.fg, bg = "NONE" })
set(0, "StatusLineNC", { fg = p.muted, bg = "NONE" })
set(0, "WinSeparator", { fg = p.muted, bg = "NONE" })
set(0, "TabLine", { fg = p.muted, bg = "NONE" })
set(0, "TabLineSel", { fg = p.accent, bg = "NONE", bold = true })
set(0, "Visual", { bg = p.bg_alt })
set(0, "Search", { fg = p.bg, bg = p.yellow })
set(0, "IncSearch", { fg = p.bg, bg = p.accent })

set(0, "Comment", { fg = p.muted, italic = true })
set(0, "Constant", { fg = p.magenta })
set(0, "String", { fg = p.green })
set(0, "Identifier", { fg = p.fg })
set(0, "Function", { fg = p.blue })
set(0, "Statement", { fg = p.accent })
set(0, "Keyword", { fg = p.accent, italic = true })
set(0, "PreProc", { fg = p.magenta })
set(0, "Type", { fg = p.yellow })
set(0, "Special", { fg = p.cyan })
set(0, "Error", { fg = p.red })
set(0, "Todo", { fg = p.bg, bg = p.yellow, bold = true })

set(0, "DiagnosticError", { fg = p.red })
set(0, "DiagnosticWarn", { fg = p.yellow })
set(0, "DiagnosticInfo", { fg = p.blue })
set(0, "DiagnosticHint", { fg = p.cyan })

vim.g.terminal_color_0 = p.bg
vim.g.terminal_color_1 = p.red
vim.g.terminal_color_2 = p.green
vim.g.terminal_color_3 = p.yellow
vim.g.terminal_color_4 = p.blue
vim.g.terminal_color_5 = p.magenta
vim.g.terminal_color_6 = p.cyan
vim.g.terminal_color_7 = p.fg
vim.g.terminal_color_8 = p.muted
vim.g.terminal_color_9 = p.red
vim.g.terminal_color_10 = p.green
vim.g.terminal_color_11 = p.yellow
vim.g.terminal_color_12 = p.blue
vim.g.terminal_color_13 = p.magenta
vim.g.terminal_color_14 = p.cyan
vim.g.terminal_color_15 = p.fg
