KITTY_COLORS="$HOME/.config/kitty/colors.conf"

update_kitty() {
    local fg=$1
    local bg=$2
    local accent=$3
    local red=$4
    local green=$5
    local yellow=$6
    local blue=$7
    local magenta=$8
    local cyan=$9

    cat > "$KITTY_COLORS" <<EOF
foreground            $fg
background            $bg
selection_foreground  $bg
selection_background  $accent
cursor                $fg
url_color             $accent

color0   $bg
color8   $bg
color1   $red
color9   $red
color2   $green
color10  $green
color3   $yellow
color11  $yellow
color4   $blue
color12  $blue
color5   $magenta
color13  $magenta
color6   $cyan
color14  $cyan
color7   $fg
color15  $fg
EOF
    killall -SIGUSR1 kitty 2>/dev/null
}

apply_theme() {
    case $1 in
        "catppuccin")
            # Hyprland
            cat > "$HYPR_COLORS" <<EOF
return {
    active_border = { colors = { "rgb(89b4fa)", "rgb(cba6f7)" }, angle = 360 },
    inactive_border = "rgba(595959aa)",
}
EOF
            # Waybar
            cat > "$WAYBAR_COLORS" <<EOF
@define-color module-bg     #11111b;
@define-color tooltip-bg    @module-bg;
@define-color inactive      #787c99;
@define-color fg            #cdd6f4;
@define-color workspace-fg  @fg;
@define-color highlight     @inactive;
@define-color red           #f38ba8;
@define-color blue          #89b4fa;
@define-color yellow        #f9e2af;
@define-color green         #a6e3a1;
EOF
            # Rofi
            cat > "$ROFI_COLORS" <<EOF
* {
    background:     #1e1e2e;
    background-alt: #181825;
    foreground:     #cdd6f4;
    selected:       #89b4fa;
    selected-fg:    #11111b;
    active:         #a6e3a1;
    urgent:         #f38ba8;
}
EOF
            update_zed "Catppuccin Mocha"
            update_gtk "#1e1e2e" "#181825" "#cdd6f4" "#89b4fa"
            update_qtct
            update_kvantum "#1e1e2e" "#181825" "#cdd6f4" "#89b4fa" "#6c7086" "#89b4fa"
            update_quickshell "#1e1e2e" "#181825" "#cdd6f4" "#6c7086" "#89b4fa" "#1e1e2e" "#6c7086"
            update_kitty "#cdd6f4" "#1e1e2e" "#89b4fa" "#f38ba8" "#a6e3a1" "#f9e2af" "#89b4fa" "#cba6f7" "#94e2d5"
            update_nvim "catppuccin" "catppuccin" "#1e1e2e" "#313244" "#cdd6f4" "#6c7086" "#89b4fa" "#f38ba8" "#a6e3a1" "#f9e2af" "#89b4fa" "#cba6f7" "#94e2d5"
            update_hyprlock "#1e1e2e" "#cdd6f4" "#89b4fa" "#f38ba8"
            update_swaync "#1e1e2e" "#181825" "#cdd6f4" "#bac2de" "#6c7086" "#89b4fa" "#11111b" "#f38ba8" "#a6e3a1"
            update_helium "#1e1e2e" "#181825" "#1e1e2e" "#cdd6f4" "#89b4fa"
            ;;
        "rose-pine")
            # Hyprland
            cat > "$HYPR_COLORS" <<EOF
return {
    active_border = { colors = { "rgb(31748f)", "rgb(9ccfd8)" }, angle = 360 },
    inactive_border = "rgba(595959aa)",
}
EOF
            # Waybar
            cat > "$WAYBAR_COLORS" <<EOF
@define-color module-bg     #191724;
@define-color tooltip-bg    @module-bg;
@define-color inactive      #6e6a86;
@define-color fg            #e0def4;
@define-color workspace-fg  @fg;
@define-color highlight     @inactive;
@define-color red           #eb6f92;
@define-color blue          #31748f;
@define-color yellow        #f6c177;
@define-color green         #9ccfd8;
EOF
            # Rofi
            cat > "$ROFI_COLORS" <<EOF
* {
    background:     #191724;
    background-alt: #1f1d2e;
    foreground:     #e0def4;
    selected:       #31748f;
    selected-fg:    #191724;
    active:         #9ccfd8;
    urgent:         #eb6f92;
}
EOF
            update_zed "Rosé Pine"
            update_gtk "#191724" "#1f1d2e" "#e0def4" "#31748f"
            update_qtct
            update_kvantum "#191724" "#1f1d2e" "#e0def4" "#31748f" "#6e6a86" "#31748f"
            update_quickshell "#191724" "#1f1d2e" "#e0def4" "#6e6a86" "#31748f" "#e0def4" "#6e6a86"
            update_kitty "#e0def4" "#191724" "#31748f" "#eb6f92" "#9ccfd8" "#f6c177" "#31748f" "#c4a7e7" "#9ccfd8"
            update_nvim "rose-pine" "rose-pine" "#191724" "#26233a" "#e0def4" "#6e6a86" "#31748f" "#eb6f92" "#9ccfd8" "#f6c177" "#31748f" "#c4a7e7" "#9ccfd8"
            update_hyprlock "#191724" "#e0def4" "#31748f" "#eb6f92"
            update_swaync "#191724" "#1f1d2e" "#e0def4" "#908caa" "#6e6a86" "#31748f" "#191724" "#eb6f92" "#9ccfd8"
            update_helium "#191724" "#1f1d2e" "#191724" "#e0def4" "#31748f"
            ;;
        "gruvbox")
            # Hyprland
            cat > "$HYPR_COLORS" <<EOF
return {
    active_border = { colors = { "rgb(83a598)", "rgb(b8bb26)" }, angle = 360 },
    inactive_border = "rgba(595959aa)",
}
EOF
            # Waybar
            cat > "$WAYBAR_COLORS" <<EOF
@define-color module-bg     #282828;
@define-color tooltip-bg    @module-bg;
@define-color inactive      #928374;
@define-color fg            #ebdbb2;
@define-color workspace-fg  @fg;
@define-color highlight     @inactive;
@define-color red           #fb4934;
@define-color blue          #83a598;
@define-color yellow        #fabd2f;
@define-color green         #b8bb26;
EOF
            # Rofi
            cat > "$ROFI_COLORS" <<EOF
* {
    background:     #282828;
    background-alt: #3c3836;
    foreground:     #ebdbb2;
    selected:       #458588;
    selected-fg:    #282828;
    active:         #98971a;
    urgent:         #cc241d;
}
EOF
            update_zed "Gruvbox Dark Hard"
            update_gtk "#282828" "#3c3836" "#ebdbb2" "#458588"
            update_qtct
            update_kvantum "#282828" "#3c3836" "#ebdbb2" "#458588" "#928374" "#458588"
            update_quickshell "#282828" "#3c3836" "#ebdbb2" "#928374" "#458588" "#ebdbb2" "#928374"
            update_kitty "#ebdbb2" "#282828" "#458588" "#fb4934" "#b8bb26" "#fabd2f" "#83a598" "#d3869b" "#8ec07c"
            update_nvim "gruvbox" "gruvbox" "#282828" "#3c3836" "#ebdbb2" "#928374" "#458588" "#fb4934" "#b8bb26" "#fabd2f" "#83a598" "#d3869b" "#8ec07c"
            update_hyprlock "#282828" "#ebdbb2" "#458588" "#fb4934"
            update_swaync "#282828" "#3c3836" "#ebdbb2" "#d5c4a1" "#928374" "#458588" "#282828" "#fb4934" "#b8bb26"
            update_helium "#282828" "#3c3836" "#282828" "#ebdbb2" "#458588"
            ;;
        "tokyonight")
            # Hyprland
            cat > "$HYPR_COLORS" <<EOF
return {
    active_border = { colors = { "rgb(7aa2f7)", "rgb(bb9af7)" }, angle = 360 },
    inactive_border = "rgba(595959aa)",
}
EOF
            # Waybar
            cat > "$WAYBAR_COLORS" <<EOF
@define-color module-bg     #1a1b26;
@define-color tooltip-bg    @module-bg;
@define-color inactive      #565f89;
@define-color fg            #c0caf5;
@define-color workspace-fg  @fg;
@define-color highlight     @inactive;
@define-color red           #f7768e;
@define-color blue          #7aa2f7;
@define-color yellow        #e0af68;
@define-color green         #9ece6a;
EOF
            # Rofi
            cat > "$ROFI_COLORS" <<EOF
* {
    background:     #1a1b26;
    background-alt: #24283b;
    foreground:     #c0caf5;
    selected:       #7aa2f7;
    selected-fg:    #1a1b26;
    active:         #9ece6a;
    urgent:         #f7768e;
}
EOF
            update_zed "Tokyo Night"
            update_gtk "#1a1b26" "#24283b" "#c0caf5" "#7aa2f7"
            update_qtct
            update_kvantum "#1a1b26" "#24283b" "#c0caf5" "#7aa2f7" "#565f89" "#7aa2f7"
            update_quickshell "#1a1b26" "#24283b" "#c0caf5" "#565f89" "#7aa2f7" "#1a1b26" "#565f89"
            update_kitty "#c0caf5" "#1a1b26" "#7aa2f7" "#f7768e" "#9ece6a" "#e0af68" "#7aa2f7" "#bb9af7" "#7dcfff"
            update_nvim "tokyonight" "tokyonight" "#1a1b26" "#24283b" "#c0caf5" "#565f89" "#7aa2f7" "#f7768e" "#9ece6a" "#e0af68" "#7aa2f7" "#bb9af7" "#7dcfff"
            update_hyprlock "#1a1b26" "#c0caf5" "#7aa2f7" "#f7768e"
            update_swaync "#1a1b26" "#24283b" "#c0caf5" "#a9b1d6" "#565f89" "#7aa2f7" "#1a1b26" "#f7768e" "#9ece6a"
            update_helium "#1a1b26" "#24283b" "#1a1b26" "#c0caf5" "#7aa2f7"
            ;;
        "matugen")
            # Generate theme from image using matugen
            if ! command -v matugen >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
                echo "matugen and jq are required for the 'matugen' theme option" >&2
                exit 1
            fi

            # optional image path as second arg, otherwise pick random wallpaper
            if [ -n "$2" ]; then
                image="$2"
            else
                wallpaper_dir=$(find_wallpaper_dir || true)
                if [ -n "${wallpaper_dir:-}" ]; then
                    image=$(find -L "$wallpaper_dir" -type f 2>/dev/null | shuf -n 1 || true)
                fi
            fi
            if [ -z "${image:-}" ] || [ ! -f "$image" ]; then
                echo "No image found for matugen theme" >&2
                exit 1
            fi

            echo "Generating colors from $image"
            json=$(matugen image "$image" -j hex --dry-run --source-color-index 0 2>/dev/null || true)
            if [ -z "${json:-}" ]; then
                echo "matugen failed to produce json" >&2
                exit 1
            fi

            get() { printf "%s" "$json" | jq -r "${1} // empty" 2>/dev/null || true; }
            surface=$(get '.colors.surface.default.color')
            on_surface=$(get '.colors.on_surface.default.color')
            primary=$(get '.colors.primary.default.color')
            on_primary=$(get '.colors.on_primary.default.color')
            secondary=$(get '.colors.secondary.default.color')
            tertiary=$(get '.colors.tertiary.default.color')
            error=$(get '.colors.error.default.color')
            outline=$(get '.colors.outline.default.color')

            # Fallbacks
            surface=${surface:-"#000000"}
            on_surface=${on_surface:-"#ffffff"}
            primary=${primary:-"${error:-$surface}"}
            on_primary=${on_primary:-$on_surface}
            secondary=${secondary:-$primary}
            tertiary=${tertiary:-$primary}
            error=${error:-"#ff0000"}
            outline=${outline:-$on_surface}

            # backup existing hypr colors
            if [ -f "$HYPR_COLORS" ]; then
                cp -a "$HYPR_COLORS" "$HYPR_COLORS.bak.$(date +%s)"
            fi

            # strip leading '#' for rgb(...) style used in some hypr configs
            primary_nohash=${primary#\#}
            tertiary_nohash=${tertiary#\#}
            awww img "$image"
            mkdir -p "$(dirname "$CURRENT_WALLPAPER")"
            printf '%s\n' "$image" > "$CURRENT_WALLPAPER"
            cat > "$HYPR_COLORS" <<EOF
return {
    active_border = { colors = { "rgb($primary_nohash)", "rgb($tertiary_nohash)" }, angle = 360 },
    inactive_border = "rgba(595959aa)",
}
EOF

            # Waybar
            cat > "$WAYBAR_COLORS" <<EOF
@define-color module-bg     $surface;
@define-color tooltip-bg    @module-bg;
@define-color inactive      $outline;
@define-color fg            $on_surface;
@define-color workspace-fg  @fg;
@define-color highlight     $outline;
@define-color red           $error;
@define-color blue          $primary;
@define-color yellow        $secondary;
@define-color green         $tertiary;
EOF

            # Rofi
            cat > "$ROFI_COLORS" <<EOF
* {
    background:     $surface;
    background-alt: $surface;
    foreground:     $on_surface;
    selected:       $primary;
    selected-fg:    $on_primary;
    active:         $tertiary;
    urgent:         $error;
}
EOF

            # GTK and QT updates
            update_gtk "$surface" "$surface" "$on_surface" "$primary"
            update_qtct
            update_kvantum "$surface" "$surface" "$on_surface" "$primary" "$outline" "$primary"
            update_quickshell "$surface" "$surface" "$on_surface" "$outline" "$primary" "$on_primary" "$outline"

            # Kitty
            update_kitty "$on_surface" "$surface" "$primary" "$error" "$tertiary" "$secondary" "$primary" "$tertiary" "$secondary"
            update_nvim "matugen" "" "$surface" "$surface" "$on_surface" "$outline" "$primary" "$error" "$tertiary" "$secondary" "$primary" "$tertiary" "$secondary"

            # Zed
            update_zed "Matugen Dark"

            # Hyprlock
            update_hyprlock "$surface" "$on_surface" "$primary" "$error"
            update_swaync "$surface" "$surface" "$on_surface" "$outline" "$outline" "$primary" "$on_primary" "$error" "$tertiary"
            if [ -r "$CURRENT_WALLPAPER" ]; then
                update_helium_from_image "$(cat "$CURRENT_WALLPAPER")"
            fi

            ;;
        "helium-wallpaper")
            local image="$2"

            if [ -z "${image:-}" ] && [ -r "$CURRENT_WALLPAPER" ]; then
                image=$(cat "$CURRENT_WALLPAPER")
            fi

            if ! update_helium_from_image "${image:-}"; then
                exit 1
            fi

            exit 0
            ;;
        *)
            echo "Unknown theme: $1"
            exit 1
            ;;
    esac

    mkdir -p "$(dirname "$CURRENT_THEME")"
    printf '%s\n' "$1" > "$CURRENT_THEME"

    # Reload services
    # Waybar restart
    killall waybar
    waybar > /dev/null 2>&1 &
    disown

    # Hyprland reload
    hyprctl reload

    # SwayNC CSS reload
    if command -v swaync-client >/dev/null 2>&1; then
        if command -v timeout >/dev/null 2>&1; then
            timeout 2s swaync-client -rs >/dev/null 2>&1 || true
        else
            swaync-client -rs >/dev/null 2>&1 &
            disown
        fi
    fi
}

if [[ "$1" == "--list" ]]; then
    list_themes
elif [[ -n "$1" ]]; then
    apply_theme "$@"
else
    echo "Usage: $0 [--list | theme_name]"
fi
